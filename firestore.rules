rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // College Information rules
    match /collegeInformation/{infoId} {
      allow read, write: if true;
    }

    // Departments rules
    match /departments/{deptId} {
      allow read, write: if true;
    }

    // Teachers & Faculty rules
    match /teachers/{teacherId} {
      allow read, write: if true;
    }
    match /faculty/{facultyId} {
      allow read, write: if true;
    }

    // Students rules
    match /students/{studentId} {
      allow read, write: if true;
    }

    // Notices & Notice Categories rules
    match /notices/{noticeId} {
      allow read, write: if true;
    }
    match /noticeCategories/{catId} {
      allow read, write: if true;
    }

    // Notes rules
    match /notes/{noteId} {
      allow read, write: if true;
    }

    // Question papers rules
    match /questionpapers/{qpId} {
      allow read, write: if true;
    }
    match /questionPapers/{qpId} {
      allow read, write: if true;
    }

    // Assignments rules
    match /assignments/{assignId} {
      allow read, write: if true;
    }

    // Blood bank rules
    match /bloodbank/{donorId} {
      allow read, write: if true;
    }
    match /bloodBank/{donorId} {
      allow read, write: if true;
    }

    // Student requests rules
    match /studentRequests/{reqId} {
      allow read, write: if true;
    }

    // Attendance rules
    match /attendance/{attendanceId} {
      allow read, write: if true;
    }

    // Complaints rules - allow public submissions and admin management
    match /complaints/{complaintId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Outsider blood donor requests rules
    match /outsiderBloodDonorRequests/{reqId} {
      allow read, write: if true;
    }

    // Outsider blood donors rules
    match /outsiderBloodDonors/{donorId} {
      allow read, write: if true;
    }

    // Attendance stats rules
    match /attendanceStats/{docId} {
      allow read, write: if true;
    }

    // Blood bank stats rules
    match /bloodBankStats/{docId} {
      allow read, write: if true;
    }

    // Admin Users (roles & permissions) — authenticated access only
    match /adminUsers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Users (roles & permissions) — authenticated access only
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Messages rules
    match /messages/{msgId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (
        request.auth.uid in resource.data.participantIds ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    // Conversations metadata rules
    match /conversations/{adminId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == adminId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    // Activity Logs — authenticated access only
    match /activityLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Logs cannot be modified or deleted
    }

    // Maintenance Control settings - public read, write restricted to Super Admin
    match /systemSettings/maintenance {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Maintenance Logs - Super Admin only
    match /maintenanceLogs/{logId} {
      allow read, create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
      allow update, delete: if false;
    }

    // System Settings — public read, write restricted to authenticated admins
    match /systemSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Announcements — public read, write restricted to authenticated admins
    match /announcements/{annId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

